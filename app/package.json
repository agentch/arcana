{
  "name": "@arcana/app",
  "version": "0.1.0",
  "private": true,
  "description": "Arcana Tarot cross-platform application",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev:h5": "taro build --type h5 --watch",
    "dev:weapp": "taro build --type weapp --watch",
    "dev:weapp:local": "TARO_LOCAL_CARD_ASSETS=true taro build --type weapp --watch",
    "build:h5": "taro build --type h5",
    "build:weapp": "taro build --type weapp",
    "build:weapp:local": "TARO_LOCAL_CARD_ASSETS=true taro build --type weapp",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests --ext .ts,.tsx",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "check": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm test",
    "validate": "pnpm check && pnpm build:h5 && pnpm build:weapp"
  },
  "browserslist": [
    "defaults and fully supports es6-module",
    "maintained node versions"
  ],
  "dependencies": {
    "@babel/runtime": "^7.24.4",
    "@tarojs/components": "4.2.1",
    "@tarojs/helper": "4.2.1",
    "@tarojs/plugin-framework-react": "4.2.1",
    "@tarojs/plugin-platform-h5": "4.2.1",
    "@tarojs/plugin-platform-weapp": "4.2.1",
    "@tarojs/react": "4.2.1",
    "@tarojs/runtime": "4.2.1",
    "@tarojs/shared": "4.2.1",
    "@tarojs/taro": "4.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@babel/core": "^7.24.4",
    "@babel/plugin-transform-class-properties": "7.25.9",
    "@babel/preset-react": "^7.24.1",
    "@tarojs/cli": "4.2.1",
    "@tarojs/vite-runner": "4.2.1",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "babel-preset-taro": "4.2.1",
    "eslint": "^8.57.0",
    "eslint-config-taro": "4.2.1",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.4.0",
    "prettier": "3.9.5",
    "sass": "^1.75.0",
    "typescript": "^5.4.5",
    "vite": "^4.5.14",
    "vitest": "0.34.6"
  }
}
