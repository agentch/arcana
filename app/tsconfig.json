{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./src/*"],
      "@arcana/tarot-core": ["../packages/tarot-core/src/index.ts"],
      "@arcana/tarot-core/*": ["../packages/tarot-core/src/*"]
    },
    "types": ["vitest/globals", "node"]
  },
  "include": ["src", "types", "config", "tests", "vitest.config.ts"],
  "compileOnSave": false
}
