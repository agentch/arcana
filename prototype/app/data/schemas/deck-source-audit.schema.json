{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arcana.local/schemas/deck-source-audit.schema.json",
  "title": "Arcana Deck Source Audit",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "deckId",
    "auditVersion",
    "auditedAt",
    "status",
    "category",
    "sourceBatchId",
    "summary",
    "files"
  ],
  "properties": {
    "schemaVersion": {"type": "string", "const": "1.0"},
    "deckId": {"const": "rws-original"},
    "auditVersion": {"type": "string", "minLength": 1},
    "auditedAt": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "status": {"const": "verified-candidate"},
    "category": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "url", "description"],
      "properties": {
        "title": {"type": "string", "minLength": 1},
        "url": {"type": "string", "minLength": 1},
        "description": {"type": "string", "minLength": 1}
      }
    },
    "sourceBatchId": {
      "type": "string",
      "pattern": "^commons-taionwc-[a-f0-9]{64}$"
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fileCount",
        "mimeType",
        "licenseShortName",
        "usageTerms",
        "artist",
        "workDate",
        "widthRange",
        "heightRange"
      ],
      "properties": {
        "fileCount": {"type": "integer", "const": 78},
        "mimeType": {"const": "image/jpeg"},
        "licenseShortName": {"const": "Public domain"},
        "usageTerms": {"const": "Public domain"},
        "artist": {"const": "Pamela Colman Smith"},
        "workDate": {"const": "1910"},
        "widthRange": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "prefixItems": [
            {"type": "integer", "minimum": 1},
            {"type": "integer", "minimum": 1}
          ],
          "items": false
        },
        "heightRange": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "prefixItems": [
            {"type": "integer", "minimum": 1},
            {"type": "integer", "minimum": 1}
          ],
          "items": false
        }
      }
    },
    "files": {
      "type": "array",
      "minItems": 78,
      "maxItems": 78,
      "items": {"$ref": "#/$defs/file"}
    }
  },
  "$defs": {
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cardId",
        "title",
        "filePageUrl",
        "originalUrl",
        "sha1",
        "width",
        "height",
        "bytes",
        "mimeType",
        "revisionUser",
        "revisionTimestamp",
        "licenseShortName",
        "usageTerms",
        "publicDomainMark",
        "pdOld80Expired"
      ],
      "properties": {
        "cardId": {"type": "string", "pattern": "^(major|minor)-[a-z0-9-]+$"},
        "title": {"type": "string", "minLength": 1},
        "filePageUrl": {"type": "string", "minLength": 1},
        "originalUrl": {"type": "string", "minLength": 1},
        "sha1": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
        "width": {"type": "integer", "minimum": 1},
        "height": {"type": "integer", "minimum": 1},
        "bytes": {"type": "integer", "minimum": 1},
        "mimeType": {"const": "image/jpeg"},
        "revisionUser": {"type": "string", "minLength": 1},
        "revisionTimestamp": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}T"
        },
        "licenseShortName": {"const": "Public domain"},
        "usageTerms": {"const": "Public domain"},
        "publicDomainMark": {"const": true},
        "pdOld80Expired": {"const": true}
      }
    }
  }
}
