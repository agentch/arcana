{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arcana.local/schemas/spreads.schema.json",
  "title": "Arcana Spreads",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "spreadsVersion", "spreads"],
  "properties": {
    "schemaVersion": {"type": "string", "const": "1.0"},
    "spreadsVersion": {"type": "string", "minLength": 1},
    "spreads": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/spread"}
    }
  },
  "$defs": {
    "position": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "prompt", "order"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
        "name": {"type": "string", "minLength": 1},
        "prompt": {"type": "string", "minLength": 1},
        "order": {"type": "integer", "minimum": 1}
      }
    },
    "spread": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "description",
        "enabled",
        "supportedTopics",
        "positions"
      ],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
        "name": {"type": "string", "minLength": 1},
        "description": {"type": "string", "minLength": 1},
        "enabled": {"type": "boolean"},
        "supportedTopics": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "positions": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/position"}
        }
      }
    }
  }
}
