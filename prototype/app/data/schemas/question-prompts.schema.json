{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arcana.local/schemas/question-prompts.schema.json",
  "title": "Arcana Question Prompts",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "promptsVersion", "categories"],
  "properties": {
    "schemaVersion": {"type": "string", "const": "1.0"},
    "promptsVersion": {"type": "string", "minLength": 1},
    "categories": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/category"}
    }
  },
  "$defs": {
    "category": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "description", "options"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
        "name": {"type": "string", "minLength": 1},
        "description": {"type": "string", "minLength": 1},
        "options": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/option"}
        }
      }
    },
    "option": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "prompt"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
        "name": {"type": "string", "minLength": 1},
        "prompt": {"type": "string", "minLength": 1}
      }
    }
  }
}
