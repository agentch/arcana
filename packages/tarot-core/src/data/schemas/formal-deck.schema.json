{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arcana.local/schemas/formal-deck.schema.json",
  "title": "Arcana Formal Deck Metadata",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "name",
    "authors",
    "edition",
    "publicationPeriod",
    "source",
    "license",
    "sourceBatchId",
    "version",
    "assetBuild"
  ],
  "properties": {
    "schemaVersion": {"type": "string", "const": "1.0"},
    "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "name": {"type": "string", "minLength": 1},
    "authors": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "edition": {"type": ["string", "null"]},
    "publicationPeriod": {"type": "string", "minLength": 1},
    "source": {"$ref": "#/$defs/source"},
    "license": {"$ref": "#/$defs/license"},
    "sourceBatchId": {"type": ["string", "null"]},
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "assetBuild": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format", "maxWidth", "quality", "fit", "withoutEnlargement"],
      "properties": {
        "format": {"const": "webp"},
        "maxWidth": {"type": "integer", "minimum": 320, "maximum": 2400},
        "quality": {"type": "integer", "minimum": 1, "maximum": 100},
        "fit": {"const": "inside"},
        "withoutEnlargement": {"const": true}
      }
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "title", "url", "publisher", "retrievedAt"],
      "properties": {
        "status": {"type": "string", "enum": ["pending-review", "verified"]},
        "title": {"type": ["string", "null"]},
        "url": {"type": ["string", "null"]},
        "publisher": {"type": ["string", "null"]},
        "retrievedAt": {
          "oneOf": [
            {"type": "null"},
            {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"}
          ]
        }
      }
    },
    "license": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "name",
        "url",
        "commercialUse",
        "modification",
        "redistribution",
        "attributionRequired",
        "notes"
      ],
      "properties": {
        "status": {"type": "string", "enum": ["pending-review", "approved", "rejected"]},
        "name": {"type": ["string", "null"]},
        "url": {"type": ["string", "null"]},
        "commercialUse": {"type": "string", "enum": ["unknown", "allowed", "prohibited"]},
        "modification": {"type": "string", "enum": ["unknown", "allowed", "prohibited"]},
        "redistribution": {"type": "string", "enum": ["unknown", "allowed", "prohibited"]},
        "attributionRequired": {"type": "string", "enum": ["unknown", "yes", "no"]},
        "notes": {"type": "string", "minLength": 1}
      }
    }
  }
}
